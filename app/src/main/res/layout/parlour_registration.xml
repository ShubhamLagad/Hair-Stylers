<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Parlour.ParlourRegistration">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="11dp"
            app:cardCornerRadius="5dp"
            android:layout_gravity="center"
            app:cardElevation="20sp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="11dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/icon_color"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Please fill the input below here"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="11dp"
                    android:textColor="@color/muted_text"/>


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_title_24"
                        android:drawablePadding="11dp"
                        android:hint="Parlour Name"
                        android:inputType="text"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/parlourName"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_subtitles_24"
                        android:drawablePadding="11dp"
                        android:hint="Subtitle"
                        android:inputType="text"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/subtitle"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_phone_android_24"
                        android:drawablePadding="11dp"
                        android:hint="Phone"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/phone"
                        android:inputType="phone"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>


                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_email_24"
                        android:drawablePadding="11dp"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/email"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_lock_24"
                        android:drawablePadding="11dp"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/password"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_lock_24"
                        android:drawablePadding="11dp"
                        android:hint="Confirm Password"
                        android:inputType="textPassword"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/cpassword"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp">
                    <AutoCompleteTextView
                        android:id="@+id/parlourTypes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:text="Choose parlour type"
                        android:textStyle="bold"
                        android:textColor="@color/icon_color"
                        android:drawableStart="@drawable/ic_lesbian_couple_4023"
                        android:drawablePadding="8dp"
                        android:background="@drawable/edit_text_format" />
                </com.google.android.material.textfield.TextInputLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">
                    <TextView
                        android:id="@+id/openTime"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Opening Time"
                        android:drawableLeft="@drawable/ic_baseline_access_time_24"
                        android:drawablePadding="11dp"
                        android:paddingHorizontal="11dp"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingVertical="8dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">
                    <TextView
                        android:id="@+id/closeTime"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Closing Time"
                        android:drawableLeft="@drawable/ic_baseline_timer_off_24"
                        android:drawablePadding="11dp"
                        android:paddingHorizontal="11dp"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingVertical="8dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_edit_location_24"
                        android:drawablePadding="11dp"
                        android:hint="Address"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/address"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:inputType="textPostalAddress"
                        android:textColor="@color/white"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_my_location_24"
                        android:drawablePadding="11dp"
                        android:hint="Pincode"
                        android:textColorHint="@color/muted_text"
                        android:id="@+id/picode"
                        android:maxLength="6"
                        android:inputType="number"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="11dp"
                        android:background="@drawable/edit_text_format"/>

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="11dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_baseline_add_photo_alternate_24"
                        android:drawablePadding="11dp"
                        android:text="Photo"
                        android:textColor="@color/icon_color"
                        android:id="@+id/photo"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginTop="11dp"
                        android:paddingHorizontal="11dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="5dp"
                        app:cardElevation="5dp">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/selectImageBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Select Image"
                            android:paddingHorizontal="21dp"
                            android:paddingVertical="3dp"
                            android:textColor="#fff"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:background="@color/second_icon_color"/>

                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="5dp"
                        app:cardElevation="5dp"
                        android:layout_marginLeft="10dp">
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/uploadImageBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Upload"
                            android:paddingHorizontal="21dp"
                            android:paddingVertical="3dp"
                            android:textColor="#fff"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:background="@color/icon_color"/>


                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="image.jpg"
                    android:layout_marginTop="11dp"
                    android:paddingHorizontal="21dp"
                    android:textSize="15sp"
                    android:textColor="@color/icon_color"/>



                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="11dp"
                    app:cardElevation="10dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/loginBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Sign Up"
                        android:paddingHorizontal="51dp"
                        android:paddingVertical="8dp"
                        android:textColor="#fff"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@color/icon_color"/>

                </androidx.cardview.widget.CardView>


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:layout_marginTop="11dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Already have a account?"
                        android:textColor="@color/muted_text"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in"
                        android:textStyle="bold"
                        android:textColor="@color/purple_700"
                        android:textSize="18sp"
                        android:id="@+id/signUpTxt"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</ScrollView>
</LinearLayout>